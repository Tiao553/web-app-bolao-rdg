# ─── BACKEND (Vercel Environment Variables) ─────────────────────────────────────
# Set in Vercel dashboard → Project → Settings → Environment Variables

DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname
API_FOOTBALL_KEY=your_api_football_key
SYNC_ADMIN_TOKEN=your_random_secret_token
FRONTEND_ORIGINS=https://your-app.vercel.app
SESSION_COOKIE_DOMAIN=your-app.vercel.app

# ─── EMAIL (Resend) ─────────────────────────────────────────────────────────────
# 1. Create account at: https://resend.com
# 2. Generate API Key at: https://resend.com/api-keys
# 3. Verify your domain at: https://resend.com/domains (or use onboarding@resend.dev for testing)

RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Bolão RDG <noreply@yourdomain.com>
FRONTEND_URL=https://your-app.vercel.app

# ─── FRONTEND (Vercel Environment Variables) ────────────────────────────────────

API_BASE_URL=https://your-backend.vercel.app
